{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prism.dev/schemas/benchmarks/telemetry.schema.json",
  "title": "PRISM Benchmark Telemetry",
  "$defs": {
    "telemetrySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_tokens",
        "completion_tokens",
        "tool_calls",
        "prism_queries",
        "prism_query_calls",
        "prism_compact_tool_calls",
        "locate_preview_requests",
        "locate_preview_hits",
        "locate_preview_bytes",
        "locate_preview_direct_opens",
        "locate_preview_direct_progressions",
        "expand_preview_requests",
        "expand_preview_hits",
        "expand_preview_bytes",
        "expand_preview_direct_opens",
        "expand_preview_direct_progressions",
        "prism_payload_bytes",
        "workspace_refresh_duration_ms",
        "workspace_refresh_lock_wait_ms",
        "workspace_refresh_lock_hold_ms",
        "workspace_refresh_snapshot_revisions_ms",
        "workspace_refresh_load_episodic_ms",
        "workspace_refresh_load_inference_ms",
        "workspace_refresh_load_coordination_ms",
        "workspace_full_reload_count",
        "workspace_auxiliary_reload_count",
        "shell_commands",
        "shell_read_commands",
        "repeated_reads",
        "patch_attempts",
        "wall_time_seconds"
      ],
      "properties": {
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "prism_queries": {
          "type": "integer",
          "minimum": 0
        },
        "prism_query_calls": {
          "type": "integer",
          "minimum": 0
        },
        "prism_compact_tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "locate_preview_requests": {
          "type": "integer",
          "minimum": 0
        },
        "locate_preview_hits": {
          "type": "integer",
          "minimum": 0
        },
        "locate_preview_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "locate_preview_direct_opens": {
          "type": "integer",
          "minimum": 0
        },
        "locate_preview_direct_progressions": {
          "type": "integer",
          "minimum": 0
        },
        "expand_preview_requests": {
          "type": "integer",
          "minimum": 0
        },
        "expand_preview_hits": {
          "type": "integer",
          "minimum": 0
        },
        "expand_preview_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "expand_preview_direct_opens": {
          "type": "integer",
          "minimum": 0
        },
        "expand_preview_direct_progressions": {
          "type": "integer",
          "minimum": 0
        },
        "prism_payload_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_lock_wait_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_lock_hold_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_snapshot_revisions_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_load_episodic_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_load_inference_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_refresh_load_coordination_ms": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_full_reload_count": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_auxiliary_reload_count": {
          "type": "integer",
          "minimum": 0
        },
        "shell_commands": {
          "type": "integer",
          "minimum": 0
        },
        "shell_read_commands": {
          "type": "integer",
          "minimum": 0
        },
        "repeated_reads": {
          "type": "integer",
          "minimum": 0
        },
        "patch_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "wall_time_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "status",
    "track",
    "cohort",
    "git_commit",
    "started_at",
    "finished_at",
    "arms"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "completed"]
    },
    "track": {
      "type": "string"
    },
    "cohort": {
      "type": "string"
    },
    "git_commit": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": ["string", "null"]
    },
    "arms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "prism_enabled",
          "summary",
          "instances"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "prism_enabled": {
            "type": "boolean"
          },
          "compact_preview_policy": {
            "type": "string",
            "enum": ["off", "adaptive"]
          },
          "summary": {
            "$ref": "#/$defs/telemetrySummary"
          },
          "instances": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "instance_id",
                "resolved",
                "prompt_tokens",
                "completion_tokens",
                "tool_calls",
                "prism_queries",
                "prism_query_calls",
                "prism_compact_tool_calls",
                "locate_preview_requests",
                "locate_preview_hits",
                "locate_preview_bytes",
                "locate_preview_direct_opens",
                "locate_preview_direct_progressions",
                "expand_preview_requests",
                "expand_preview_hits",
                "expand_preview_bytes",
                "expand_preview_direct_opens",
                "expand_preview_direct_progressions",
                "prism_payload_bytes",
                "workspace_refresh_duration_ms",
                "workspace_refresh_lock_wait_ms",
                "workspace_refresh_lock_hold_ms",
                "workspace_refresh_snapshot_revisions_ms",
                "workspace_refresh_load_episodic_ms",
                "workspace_refresh_load_inference_ms",
                "workspace_refresh_load_coordination_ms",
                "workspace_full_reload_count",
                "workspace_auxiliary_reload_count",
                "shell_commands",
                "shell_read_commands",
                "repeated_reads",
                "patch_attempts",
                "wall_time_seconds"
              ],
              "properties": {
                "instance_id": {
                  "type": "string"
                },
                "resolved": {
                  "type": ["boolean", "null"]
                },
                "prompt_tokens": {
                  "type": "integer",
                  "minimum": 0
                },
                "completion_tokens": {
                  "type": "integer",
                  "minimum": 0
                },
                "tool_calls": {
                  "type": "integer",
                  "minimum": 0
                },
                "prism_queries": {
                  "type": "integer",
                  "minimum": 0
                },
                "prism_query_calls": {
                  "type": "integer",
                  "minimum": 0
                },
                "prism_compact_tool_calls": {
                  "type": "integer",
                  "minimum": 0
                },
                "locate_preview_requests": {
                  "type": "integer",
                  "minimum": 0
                },
                "locate_preview_hits": {
                  "type": "integer",
                  "minimum": 0
                },
                "locate_preview_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "locate_preview_direct_opens": {
                  "type": "integer",
                  "minimum": 0
                },
                "locate_preview_direct_progressions": {
                  "type": "integer",
                  "minimum": 0
                },
                "expand_preview_requests": {
                  "type": "integer",
                  "minimum": 0
                },
                "expand_preview_hits": {
                  "type": "integer",
                  "minimum": 0
                },
                "expand_preview_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "expand_preview_direct_opens": {
                  "type": "integer",
                  "minimum": 0
                },
                "expand_preview_direct_progressions": {
                  "type": "integer",
                  "minimum": 0
                },
                "prism_payload_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_duration_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_lock_wait_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_lock_hold_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_snapshot_revisions_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_load_episodic_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_load_inference_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_refresh_load_coordination_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_full_reload_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "workspace_auxiliary_reload_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "shell_commands": {
                  "type": "integer",
                  "minimum": 0
                },
                "shell_read_commands": {
                  "type": "integer",
                  "minimum": 0
                },
                "repeated_reads": {
                  "type": "integer",
                  "minimum": 0
                },
                "patch_attempts": {
                  "type": "integer",
                  "minimum": 0
                },
                "wall_time_seconds": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  }
}
